---
import { PASOS_RESERVACION, WHATSAPP_BASE_URL } from '../data/siteData';
---

<section id="proceso" class="py-20 md:py-28 bg-ivory">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-up">
      <div class="ornament mb-4">
        <span class="text-champagne text-2xl">✦</span>
      </div>
      <h2 class="section-title font-serif text-3xl sm:text-4xl md:text-5xl text-navy font-bold mb-6">
        ¿Cómo reservar?
      </h2>
      <p class="text-navy/70 text-base sm:text-lg max-w-2xl mx-auto">
        Reservar tu evento en Salón Diego's es muy sencillo. Sigue estos pasos:
      </p>
    </div>

    <!-- Steps -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      {PASOS_RESERVACION.map((paso, i) => (
        <div class="fade-up text-center group" style={`transition-delay: ${i * 0.1}s;`}>
          <div class="relative mb-6">
            <div class="w-20 h-20 mx-auto rounded-full bg-champagne/10 flex items-center justify-center group-hover:bg-champagne/20 transition-all duration-500 group-hover:scale-110">
              <span class="font-serif text-3xl text-champagne font-bold">{paso.numero}</span>
            </div>
            {i < PASOS_RESERVACION.length - 1 && (
              <div class="hidden lg:block absolute top-10 left-[calc(50%+40px)] w-[calc(100%-80px)] h-px bg-beige-dark/40"></div>
            )}
          </div>
          <h3 class="content-title font-serif text-lg text-navy font-semibold mb-2">{paso.titulo}</h3>
          <p class="text-navy/60 text-sm leading-relaxed">{paso.descripcion}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center fade-up">
      <a
        href={`${WHATSAPP_BASE_URL}?text=${encodeURIComponent('Hola, me gustaría comenzar mi cotización para un evento en Salón Diego\'s.')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-champagne to-champagne-dark text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1"
      >
        Comenzar mi cotización
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
