---
import { EVENTOS, WHATSAPP_BASE_URL } from '../data/siteData';
---

<section id="eventos" class="py-20 md:py-28 bg-ivory">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-up">
      <div class="ornament mb-4">
        <span class="text-champagne text-2xl">✦</span>
      </div>
      <h2 class="section-title font-serif text-3xl sm:text-4xl md:text-5xl text-navy font-bold mb-6">
        Celebraciones para cada ocasión
      </h2>
      <p class="text-navy/70 text-base sm:text-lg max-w-2xl mx-auto">
        Sin importar la ocasión, tenemos el espacio ideal para convertir tu evento en un recuerdo extraordinario.
      </p>
    </div>

    <!-- Event Cards Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {EVENTOS.map((evento, i) => (
        <div class="fade-up group" style={`transition-delay: ${i * 0.1}s;`}>
          <div class="relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 bg-white h-full flex flex-col">
            <!-- Image -->
            <div class="relative h-56 overflow-hidden">
              <img
                src={evento.imagen}
                alt={evento.nombre}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/50 to-transparent"></div>
              <h3 class="content-title absolute bottom-4 left-5 font-serif text-xl text-white font-semibold">
                {evento.nombre}
              </h3>
            </div>

            <!-- Content -->
            <div class="p-6 flex flex-col flex-1">
              <p class="text-navy/70 text-sm leading-relaxed mb-5 flex-1">
                {evento.descripcion}
              </p>
              <a
                href={`${WHATSAPP_BASE_URL}?text=${encodeURIComponent(evento.mensajeWA)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-champagne/10 hover:bg-champagne text-champagne-dark hover:text-white font-semibold text-sm rounded-full transition-all duration-300 group/btn"
              >
                <span>Quiero cotizar este evento</span>
                <svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
