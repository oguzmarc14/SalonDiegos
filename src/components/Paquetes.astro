---
import { PAQUETES, WHATSAPP_BASE_URL } from '../data/siteData';
---

<section id="paquetes" class="py-20 md:py-28 bg-ivory">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-up">
      <div class="ornament mb-4">
        <span class="text-champagne text-2xl">✦</span>
      </div>
      <h2 class="section-title font-serif text-3xl sm:text-4xl md:text-5xl text-navy font-bold mb-6">
        Paquetes para tu evento
      </h2>
      <p class="text-navy/70 text-base sm:text-lg max-w-2xl mx-auto">
        Elige el paquete que mejor se adapte a tu celebración, o platícanos tu idea y creamos uno a la medida.
      </p>
    </div>

    <!-- Packages Grid -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 items-start">
      {PAQUETES.map((paquete, i) => (
        <div class="fade-up" style={`transition-delay: ${i * 0.15}s;`}>
          <div class={`relative rounded-2xl bg-white shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden h-full flex flex-col ${paquete.popular ? 'package-popular' : 'border border-beige'}`}>
            <!-- Header -->
            <div class={`p-8 pb-6 text-center ${paquete.popular ? 'bg-gradient-to-br from-champagne/5 to-champagne/10' : ''}`}>
              <h3 class="content-title font-serif text-2xl text-navy font-bold mb-2">
                {paquete.nombre}
              </h3>
              <p class="text-navy/60 text-sm">
                {paquete.subtitulo}
              </p>
              <div class="mt-5 mb-2">
                <span class="font-serif text-lg text-champagne-dark font-semibold italic">
                  Solicita cotización
                </span>
              </div>
            </div>

            <!-- Divider -->
            <div class="mx-8 h-px bg-beige"></div>

            <!-- Features List -->
            <div class="p-8 pt-6 flex-1">
              <ul class="space-y-3">
                {paquete.items.map((item) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-champagne flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-navy/70 text-sm">{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Button -->
            <div class="p-8 pt-4">
              <a
                href={`${WHATSAPP_BASE_URL}?text=${encodeURIComponent(paquete.mensajeWA)}`}
                target="_blank"
                rel="noopener noreferrer"
                class={`w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-full font-semibold text-sm transition-all duration-300 hover:-translate-y-0.5 ${
                  paquete.popular
                    ? 'bg-gradient-to-r from-champagne to-champagne-dark text-white shadow-lg hover:shadow-xl'
                    : 'bg-champagne/10 text-champagne-dark hover:bg-champagne hover:text-white'
                }`}
              >
                {paquete.botonTexto}
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
