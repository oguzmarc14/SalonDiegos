---
import { SITE_INFO, WHATSAPP_BASE_URL } from '../data/siteData';
---

<section id="ubicacion" class="py-20 md:py-28 bg-ivory">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-up">
      <div class="ornament mb-4">
        <span class="text-champagne text-2xl">✦</span>
      </div>
      <h2 class="section-title font-serif text-3xl sm:text-4xl md:text-5xl text-navy font-bold mb-6">
        Ven a conocer Salón Diego's
      </h2>
      <p class="text-navy/70 text-base sm:text-lg max-w-2xl mx-auto">
        Visítanos en Encarnación de Díaz, Jalisco, y descubre el espacio perfecto para tu celebración.
      </p>
    </div>

    <!-- Map Card -->
    <div class="fade-up bg-white rounded-2xl shadow-xl overflow-hidden border border-beige/30">
      <!-- Map embed -->
      <div class="w-full h-72 md:h-96 bg-beige relative">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14814.72!2d-102.24!3d21.52!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x842984b6d9dd07d!2sSalon%20de%20eventos%20Diego's!5e0!3m2!1ses!2smx!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Salón Diego's en Google Maps"
          class="absolute inset-0"
        ></iframe>
      </div>

      <!-- Info -->
      <div class="p-8 md:p-10">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <div>
            <h3 class="content-title font-serif text-xl text-navy font-semibold mb-2">{SITE_INFO.name}</h3>
            <p class="text-navy/60 text-sm flex items-center gap-2">
              <svg class="w-4 h-4 text-champagne" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
              </svg>
              {SITE_INFO.location}
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={SITE_INFO.wazeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#33CCFF]/10 hover:bg-[#33CCFF]/20 text-[#0099CC] font-semibold text-sm rounded-full transition-all duration-300"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.54 6.63c-1.17-4.22-5.07-5.57-7.53-5.57h-.5C9.95 1.06 6.17 2.82 4.54 6.08 2.81 9.51 3.67 13.69 7.26 16.63c.12.1.19.26.19.42v2.66c0 .71.58 1.29 1.29 1.29h6.52c.71 0 1.29-.58 1.29-1.29v-2.66c0-.16.07-.32.19-.42 2.46-2.01 3.7-4.5 3.7-7.26 0-1.27-.3-2.1-.9-2.74zM9 11a1.5 1.5 0 110-3 1.5 1.5 0 010 3zm6 0a1.5 1.5 0 110-3 1.5 1.5 0 010 3z"/>
              </svg>
              Cómo llegar con Waze
            </a>
            <a
              href={`${WHATSAPP_BASE_URL}?text=${encodeURIComponent('Hola, me gustaría agendar una visita para conocer Salón Diego\'s.')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-champagne/10 hover:bg-champagne text-champagne-dark hover:text-white font-semibold text-sm rounded-full transition-all duration-300"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              Agendar una visita
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
