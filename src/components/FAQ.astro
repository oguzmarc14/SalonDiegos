---
import { FAQ } from '../data/siteData';
---

<section id="faq" class="py-20 md:py-28 bg-ivory">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-up">
      <div class="ornament mb-4">
        <span class="text-champagne text-2xl">✦</span>
      </div>
      <h2 class="section-title font-serif text-3xl sm:text-4xl md:text-5xl text-navy font-bold mb-6">
        Preguntas frecuentes
      </h2>
      <p class="text-navy/70 text-base sm:text-lg max-w-2xl mx-auto">
        Resolvemos las dudas más comunes sobre nuestros servicios.
      </p>
    </div>

    <!-- FAQ Items -->
    <div class="space-y-4 fade-up">
      {FAQ.map((item, i) => (
        <div class="faq-item bg-white rounded-xl border border-beige/50 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden">
          <button
            class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left gap-4"
            aria-expanded="false"
          >
            <span class="font-serif text-base sm:text-lg text-navy font-semibold pr-4">{item.pregunta}</span>
            <svg class="faq-icon w-5 h-5 text-champagne flex-shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-5 pt-0">
              <p class="text-navy/65 text-sm leading-relaxed">{item.respuesta}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqToggles = document.querySelectorAll('.faq-toggle');

    faqToggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const answer = toggle.nextElementSibling;
        const icon = toggle.querySelector('.faq-icon');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-icon').forEach(ic => ic.classList.remove('rotate-180'));
        document.querySelectorAll('.faq-toggle').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Open clicked one if it was closed
        if (!isOpen) {
          answer?.classList.add('open');
          icon?.classList.add('rotate-180');
          toggle.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
