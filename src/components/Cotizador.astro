---
import { WHATSAPP_BASE_URL, EVENTOS } from '../data/siteData';

const tiposEvento = EVENTOS.map(e => e.nombre);
---

<section id="cotizador" class="py-20 md:py-28 bg-ivory">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 fade-up">
      <div class="ornament mb-4">
        <span class="text-champagne text-2xl">✦</span>
      </div>
      <h2 class="section-title font-serif text-3xl sm:text-4xl md:text-5xl text-navy font-bold mb-6">
        Cuéntanos cómo imaginas tu evento
      </h2>
      <p class="text-navy/70 text-base sm:text-lg max-w-2xl mx-auto">
        Completa los datos y te enviaremos una propuesta personalizada por WhatsApp.
      </p>
    </div>

    <!-- Form -->
    <div class="fade-up bg-white rounded-2xl shadow-xl p-8 md:p-10 border border-beige/50">
      <form id="cotizador-form" class="space-y-6">
        <!-- Nombre -->
        <div>
          <label for="cot-nombre" class="block text-sm font-medium text-navy mb-2">Tu nombre</label>
          <input
            type="text"
            id="cot-nombre"
            name="nombre"
            placeholder="¿Cómo te llamas?"
            class="w-full px-4 py-3 rounded-xl border border-beige bg-ivory/50 text-navy placeholder-navy/40 focus:outline-none focus:border-champagne focus:ring-2 focus:ring-champagne/20 transition-all duration-300"
            required
          />
        </div>

        <!-- Tipo de evento -->
        <div>
          <label for="cot-tipo" class="block text-sm font-medium text-navy mb-2">Tipo de evento</label>
          <select
            id="cot-tipo"
            name="tipo"
            class="w-full px-4 py-3 rounded-xl border border-beige bg-ivory/50 text-navy focus:outline-none focus:border-champagne focus:ring-2 focus:ring-champagne/20 transition-all duration-300 appearance-none"
            required
          >
            <option value="">Selecciona un tipo de evento</option>
            {tiposEvento.map((tipo) => (
              <option value={tipo}>{tipo}</option>
            ))}
            <option value="Otro">Otro</option>
          </select>
        </div>

        <!-- Fecha -->
        <div>
          <label for="cot-fecha" class="block text-sm font-medium text-navy mb-2">Fecha aproximada</label>
          <input
            type="date"
            id="cot-fecha"
            name="fecha"
            class="w-full px-4 py-3 rounded-xl border border-beige bg-ivory/50 text-navy focus:outline-none focus:border-champagne focus:ring-2 focus:ring-champagne/20 transition-all duration-300"
          />
        </div>

        <!-- Invitados -->
        <div>
          <label for="cot-invitados" class="block text-sm font-medium text-navy mb-2">Número aproximado de invitados</label>
          <input
            type="number"
            id="cot-invitados"
            name="invitados"
            placeholder="Ej. 150"
            min="1"
            class="w-full px-4 py-3 rounded-xl border border-beige bg-ivory/50 text-navy placeholder-navy/40 focus:outline-none focus:border-champagne focus:ring-2 focus:ring-champagne/20 transition-all duration-300"
          />
        </div>

        <!-- Paquete de interés -->
        <div>
          <label for="cot-paquete" class="block text-sm font-medium text-navy mb-2">Paquete de interés</label>
          <select
            id="cot-paquete"
            name="paquete"
            class="w-full px-4 py-3 rounded-xl border border-beige bg-ivory/50 text-navy focus:outline-none focus:border-champagne focus:ring-2 focus:ring-champagne/20 transition-all duration-300 appearance-none"
          >
            <option value="">Selecciona un paquete</option>
            <option value="Esencial">Paquete Esencial</option>
            <option value="Celebración">Paquete Celebración</option>
            <option value="Todo Incluido">Paquete Todo Incluido</option>
            <option value="Personalizado">Quiero un paquete personalizado</option>
          </select>
        </div>

        <!-- Servicios adicionales -->
        <div>
          <label for="cot-servicios" class="block text-sm font-medium text-navy mb-2">Servicios adicionales o comentarios</label>
          <textarea
            id="cot-servicios"
            name="servicios"
            rows="3"
            placeholder="¿Necesitas algo especial? Decoración temática, DJ, catering, etc."
            class="w-full px-4 py-3 rounded-xl border border-beige bg-ivory/50 text-navy placeholder-navy/40 focus:outline-none focus:border-champagne focus:ring-2 focus:ring-champagne/20 transition-all duration-300 resize-none"
          ></textarea>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r from-champagne to-champagne-dark text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-base"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar disponibilidad por WhatsApp
        </button>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ WHATSAPP_BASE_URL }}>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('cotizador-form');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      const nombre = (document.getElementById('cot-nombre')).value;
      const tipo = (document.getElementById('cot-tipo')).value;
      const fecha = (document.getElementById('cot-fecha')).value;
      const invitados = (document.getElementById('cot-invitados')).value;
      const paquete = (document.getElementById('cot-paquete')).value;
      const servicios = (document.getElementById('cot-servicios')).value;

      let mensaje = `Hola, soy ${nombre}. Me gustaría solicitar información sobre Salón Diego's.\n\n`;

      if (tipo) mensaje += `📌 Tipo de evento: ${tipo}\n`;
      if (fecha) mensaje += `📅 Fecha aproximada: ${fecha}\n`;
      if (invitados) mensaje += `👥 Invitados aprox.: ${invitados}\n`;
      if (paquete) mensaje += `📦 Paquete de interés: ${paquete}\n`;
      if (servicios) mensaje += `💬 Comentarios: ${servicios}\n`;

      mensaje += `\n¿Me pueden compartir disponibilidad y una cotización?`;

      const url = `${WHATSAPP_BASE_URL}?text=${encodeURIComponent(mensaje)}`;
      window.open(url, '_blank');
    });
  });
</script>
