---
import { SITE_INFO, NAV_LINKS, WHATSAPP_BASE_URL } from '../data/siteData';
---

<footer class="bg-navy text-white/80">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <h3 class="footer-brand-title font-serif text-2xl text-white font-bold mb-4">{SITE_INFO.name}</h3>
        <p class="text-white/50 text-sm leading-relaxed mb-4">
          Un espacio elegante para tus celebraciones más importantes en {SITE_INFO.location}.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a
            href={SITE_INFO.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-champagne flex items-center justify-center transition-all duration-300"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href={SITE_INFO.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-champagne flex items-center justify-center transition-all duration-300"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href={`${WHATSAPP_BASE_URL}?text=${encodeURIComponent('Hola, quisiera más información sobre Salón Diego\'s.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-[#25D366] flex items-center justify-center transition-all duration-300"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="footer-heading text-white font-semibold text-sm uppercase mb-4">Navegación</h4>
        <ul class="space-y-2">
          {NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-white/50 hover:text-champagne text-sm transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="footer-heading text-white font-semibold text-sm uppercase mb-4">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-champagne flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
            </svg>
            <span class="text-white/50 text-sm">{SITE_INFO.location}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-champagne flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/>
            </svg>
            <a href={`${WHATSAPP_BASE_URL}`} target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-champagne text-sm transition-colors">
              WhatsApp: {SITE_INFO.phone}
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-champagne flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.54 6.63c-1.17-4.22-5.07-5.57-7.53-5.57h-.5C9.95 1.06 6.17 2.82 4.54 6.08 2.81 9.51 3.67 13.69 7.26 16.63c.12.1.19.26.19.42v2.66c0 .71.58 1.29 1.29 1.29h6.52c.71 0 1.29-.58 1.29-1.29v-2.66c0-.16.07-.32.19-.42 2.46-2.01 3.7-4.5 3.7-7.26 0-1.27-.3-2.1-.9-2.74zM9 11a1.5 1.5 0 110-3 1.5 1.5 0 010 3zm6 0a1.5 1.5 0 110-3 1.5 1.5 0 010 3z"/>
            </svg>
            <a href={SITE_INFO.wazeUrl} target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-champagne text-sm transition-colors">
              Cómo llegar (Waze)
            </a>
          </li>
        </ul>
      </div>

      <!-- Quick Actions -->
      <div>
        <h4 class="footer-heading text-white font-semibold text-sm uppercase mb-4">Acciones rápidas</h4>
        <div class="space-y-3">
          <a
            href={`${WHATSAPP_BASE_URL}?text=${encodeURIComponent('Hola, me gustaría consultar disponibilidad en Salón Diego\'s.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-5 py-3 bg-champagne/10 hover:bg-champagne text-champagne hover:text-white font-semibold text-sm rounded-full transition-all duration-300"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/>
            </svg>
            Consultar disponibilidad
          </a>
          <a
            href="#cotizador"
            class="flex items-center gap-2 px-5 py-3 bg-white/5 hover:bg-white/10 text-white/60 hover:text-white font-medium text-sm rounded-full transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 15.75l-2.489-2.489m0 0a3.375 3.375 0 10-4.773-4.773 3.375 3.375 0 004.774 4.774zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Cotizador rápido
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs text-center sm:text-left">
        © {new Date().getFullYear()} {SITE_INFO.name}. Desarrollado por Marco Webs Studio. Todos los derechos reservados.
      </p>
      <a href="#" class="text-white/30 text-center hover:text-white/60 text-xs transition-colors">
        Aviso de privacidad
      </a>
    </div>
  </div>
</footer>
