---
import { TESTIMONIOS } from '../data/siteData';
---

<section id="testimonios" class="py-20 md:py-28 bg-ivory">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-up">
      <div class="ornament mb-4">
        <span class="text-champagne text-2xl">✦</span>
      </div>
      <h2 class="section-title font-serif text-3xl sm:text-4xl md:text-5xl text-navy font-bold mb-6">
        Lo que dicen nuestros clientes
      </h2>
      <p class="text-navy/70 text-base sm:text-lg max-w-2xl mx-auto">
        Las experiencias de quienes han celebrado con nosotros son nuestra mejor carta de presentación.
      </p>
    </div>

    <!-- Testimonials -->
    <div class="grid md:grid-cols-3 gap-6 fade-up">
      {TESTIMONIOS.map((testimonio, i) => {
        const initials = testimonio.nombre
          .split(' ')
          .filter(Boolean)
          .map((part) => part[0])
          .join('')
          .slice(0, 2)
          .toUpperCase();

        return (
          <div
            class="group rounded-3xl bg-white p-8 shadow-lg border border-beige/40 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500"
            style={`transition-delay: ${i * 0.12}s;`}
          >
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-1">
                {Array.from({ length: testimonio.estrellas }).map(() => (
                  <svg class="w-4 h-4 text-champagne" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <svg class="w-10 h-10 text-champagne/20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M7.17 6A5.99 5.99 0 0 0 1.5 11.97V18h6v-6H4.3c0-2.24 1.13-3.52 2.87-4.01V6zm10.83 0a5.99 5.99 0 0 0-5.67 5.97V18h6v-6h-2.83c0-2.24 1.13-3.52 2.87-4.01V6z" />
              </svg>
            </div>

            <p class="text-navy/70 italic text-sm leading-relaxed mb-8 min-h-[7rem]">
              “{testimonio.texto}”
            </p>

            <div class="flex items-center gap-4 pt-5 border-t border-beige/40">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-champagne/20 to-champagne-dark/20 flex items-center justify-center text-champagne-dark font-serif font-semibold">
                {initials}
              </div>
              <div>
                <p class="text-navy font-semibold text-sm leading-tight">{testimonio.nombre}</p>
                <p class="text-navy/50 text-xs mt-1">{testimonio.evento}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Note -->
    <p class="text-center text-navy/40 text-xs mt-8 fade-up">
      Opiniones reales compartidas por clientes de Salón Diego's.
    </p>
  </div>
</section>
